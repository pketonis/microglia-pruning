   "source": [
    "section_header(4, 'Multi-Dataset Accuracy Evaluation', '60-90 min')\n",
    "\n",
    "def evaluate_dataset(system, examples, scorer, use_pruning, max_new_tokens=256, desc=''):\n",
    "    \"\"\"Evaluate system on a list of examples using the given scorer function.\"\"\"\n",
    "    correct, total = 0, 0\n",
    "    predictions = []\n",
    "    for ex in tqdm(examples, desc=desc):\n",
    "        try:\n",
    "            pred = system.generate(\n",
    "                ex['question'],\n",
    "                use_pruning=use_pruning,\n",
    "                max_new_tokens=max_new_tokens\n",
    "            )\n",
    "            is_correct = scorer(pred, ex['answer'])\n",
    "            predictions.append(int(is_correct))\n",
    "            correct += int(is_correct)\n",
    "        except Exception as e:\n",
    "            predictions.append(0)\n",
    "        total += 1\n",
    "    return {\n",
    "        'accuracy': correct / total if total > 0 else 0.0,\n",
    "        'correct': correct, 'total': total,\n",
    "        'predictions': predictions\n",
    "    }\n",
    "\n",
    "MULTI_RESULTS = partial_results.get('multi_results', {})\n",
    "\n",
    "DATASETS_TO_RUN = {\n",
    "    'gsm8k':         {'max_samples': EVAL_SAMPLES, 'max_new_tokens': 128},\n",
    "    'math':          {'max_samples': min(EVAL_SAMPLES, 200), 'max_new_tokens': 256},\n",
    "    'bigbench_hard': {'max_samples': None, 'max_new_tokens': 64},  # uses max_per_task\n",
    "}\n",
    "\n",
    "for ds_name, ds_cfg in DATASETS_TO_RUN.items():\n",
    "    if ds_name in MULTI_RESULTS:\n",
    "        print(f'⏭️  Skipping {ds_name} (already in partial results)')\n",
    "        continue\n",
    "    cfg = DATASET_CONFIG[ds_name]\n",
    "    print(f'\\n🔬 Evaluating on {cfg[\"label\"]}...')\n",
    "    try:\n",
    "        examples = cfg['loader'](max_samples=ds_cfg['max_samples']) if ds_name != 'bigbench_hard' \
",
    "            else cfg['loader']()\n",
    "        scorer = cfg['scorer']\n",
    "        mtok = ds_cfg['max_new_tokens']\n",
    "        baseline = evaluate_dataset(system, examples, scorer, use_pruning=False, max_new_tokens=mtok, desc=f'{ds_name} baseline')\n",
    "        pruned   = evaluate_dataset(system, examples, scorer, use_pruning=True,  max_new_tokens=mtok, desc=f'{ds_name} pruned')\n",
    "        b_arr = np.array(baseline['predictions'])\n",
    "        p_arr = np.array(pruned['predictions'])\n",
    "        n = min(len(b_arr), len(p_arr))\n",
    "        b_ci = bootstrap_ci(b_arr, num_bootstrap=1000)\n",
    "        p_ci = bootstrap_ci(p_arr, num_bootstrap=1000)\n",
    "        pair = paired_bootstrap_test(b_arr[:n], p_arr[:n], num_bootstrap=1000)\n",
    "        MULTI_RESULTS[ds_name] = {\n",
    "            'label': cfg['label'],\n",
    "            'baseline': baseline, 'pruned': pruned,\n",
    "            'baseline_ci': b_ci, 'pruned_ci': p_ci,\n",
    "            'paired': {\n",
    "                'p_value': float(pair.p_value),\n",
    "                'effect_size': float(pair.effect_size),\n",
    "                'ci_low': float(pair.ci_low),\n",
    "                'ci_high': float(pair.ci_high),\n",
    "            }\n",
    "        }\n",
    "        print(f'  ✅ {cfg[\"label\"]}: baseline={baseline[\"accuracy\"]:.2%}, pruned={pruned[\"accuracy\"]:.2%}, p={pair.p_value:.4f}')\n",
    "    except Exception as e:\n",
    "        print(f'  ❌ {ds_name} failed: {e}')\n",
    "        MULTI_RESULTS[ds_name] = {'error': str(e)}\n",
    "    finally:\n",
    "        partial_results['multi_results'] = MULTI_RESULTS\n",
    "        save_partial(); print_gpu(f'after {ds_name}')\n"
   ]
