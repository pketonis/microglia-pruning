   "source": ["## Section 10 — Multi-Dataset Visualization"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "section_header(10, 'Multi-Dataset Visualization', '2 min')\n",
    "\n",
    "valid = {k: v for k, v in MULTI_RESULTS.items() if 'error' not in v}\n",
    "if valid:\n",
    "    labels = [v['label'] for v in valid.values()]\n",
    "    base_accs = [v['baseline']['accuracy'] for v in valid.values()]\n",
    "    prn_accs  = [v['pruned']['accuracy']   for v in valid.values()]\n",
    "    base_lo = [v['baseline_ci']['ci_low']  for v in valid.values()]\n",
    "    base_hi = [v['baseline_ci']['ci_high'] for v in valid.values()]\n",
    "    prn_lo  = [v['pruned_ci']['ci_low']    for v in valid.values()]\n",
    "    prn_hi  = [v['pruned_ci']['ci_high']   for v in valid.values()]\n",
    "\n",
    "    x = np.arange(len(labels)); w = 0.35\n",
    "    fig, ax = plt.subplots(figsize=(10, 6))\n",
    "    bars1 = ax.bar(x-w/2, base_accs, w, label='Baseline', color='#3498db', alpha=0.85)\n",
    "    bars2 = ax.bar(x+w/2, prn_accs,  w, label='Pruned',   color='#e74c3c', alpha=0.85)\n",
    "    # Error bars from bootstrap CIs\n",
    "    ax.errorbar(x-w/2, base_accs,\n",
    "        yerr=[np.array(base_accs)-np.array(base_lo), np.array(base_hi)-np.array(base_accs)],\n",
    "        fmt='none', color='black', capsize=4, lw=1.5)\n",
    "    ax.errorbar(x+w/2, prn_accs,\n",
    "        yerr=[np.array(prn_accs)-np.array(prn_lo), np.array(prn_hi)-np.array(prn_accs)],\n",
    "        fmt='none', color='black', capsize=4, lw=1.5)\n",
    "    ax.set_xticks(x); ax.set_xticklabels(labels, fontsize=12)\n",
    "    ax.set_ylabel('Accuracy'); ax.set_title('Baseline vs Pruned Accuracy (95% CI)')\n",
    "    ax.legend(); ax.set_ylim(0, 1.05)\n",
    "    for bar in bars1: ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.01, f'{bar.get_height():.2%}', ha='center', va='bottom', fontsize=8)\n",
    "    for bar in bars2: ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.01, f'{bar.get_height():.2%}', ha='center', va='bottom', fontsize=8)\n",
    "    plt.tight_layout(); save_figure(fig, 'multi_dataset_comparison')\n"
