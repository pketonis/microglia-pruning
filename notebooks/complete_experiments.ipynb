   "source": ["## Section 2 — Dataset Loaders (GSM8K · MATH · BIG-Bench Hard)"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "from datasets import load_dataset\n",
    "import re\n",
    "\n",
    "# ── GSM8K ──────────────────────────────────────────────────────────────────\n",
    "def load_gsm8k(split='test', max_samples=None):\n",
    "    ds = load_dataset('gsm8k', 'main', split=split)\n",
    "    if max_samples: ds = ds.select(range(min(max_samples, len(ds))))\n",
    "    return [{'question': r['question'], 'answer': r['answer'].split('####')[-1].strip()} for r in ds]\n",
    "\n",
    "# ── MATH ───────────────────────────────────────────────────────────────────\n",
    "def load_math(split='test', max_samples=None, subjects=None):\n",
    "    \"\"\"Load Hendrycks MATH dataset. Optionally filter by subject list.\"\"\"\n",
    "    ds = load_dataset('hendrycks/competition_math', split=split, trust_remote_code=True)\n",
    "    if subjects:\n",
    "        ds = ds.filter(lambda x: x['type'] in subjects)\n",
    "    if max_samples: ds = ds.select(range(min(max_samples, len(ds))))\n",
    "    return [{'question': r['problem'], 'answer': r['solution'], 'subject': r['type'], 'level': r['level']} for r in ds]\n",
    "\n",
    "# ── BIG-Bench Hard ─────────────────────────────────────────────────────────\n",
    "BBH_TASKS = [\n",
    "    'logical_deduction_five_objects',\n",
    "    'causal_judgement',\n",
    "    'date_understanding',\n",
    "    'tracking_shuffled_objects_five_objects',\n",
    "    'web_of_lies',\n",
    "]\n",
    "\n",
    "def load_bigbench_hard(tasks=None, max_per_task=40):\n",
    "    \"\"\"Load BIG-Bench Hard tasks and flatten into a unified list.\"\"\"\n",
    "    if tasks is None: tasks = BBH_TASKS\n",
    "    all_examples = []\n",
    "    for task in tasks:\n",
    "        try:\n",
    "            ds = load_dataset('lukaemon/bbh', task, split='test', trust_remote_code=True)\n",
    "            examples = list(ds)[:max_per_task]\n",
    "            for ex in examples:\n",
    "                all_examples.append({\n",
    "                    'question': ex['input'],\n",
    "                    'answer': ex['target'],\n",
    "                    'task': task\n",
    "                })\n",
    "        except Exception as e:\n",
    "            print(f'⚠️  Could not load BBH task {task}: {e}')\n",
    "    print(f'Loaded {len(all_examples)} BIG-Bench Hard examples across {len(tasks)} tasks')\n",
    "    return all_examples\n",
    "\n",
    "# ── Answer extraction helpers ───────────────────────────────────────────────\n",
    "def extract_number(text):\n",
    "    \"\"\"Extract last number from model output for GSM8K/MATH scoring.\"\"\"\n",
    "    nums = re.findall(r'-?\\d+\\.?\\d*', text.replace(',', ''))\n",
    "    return nums[-1] if nums else None\n",
    "\n",
    "def extract_boxed(text):\n",
    "    \"\"\"Extract \\boxed{} answer for MATH dataset.\"\"\"\n",
    "    m = re.search(r'\\\\boxed\\{([^}]+)\\}', text)\n",
    "    return m.group(1).strip() if m else extract_number(text)\n",
    "\n",
    "def score_gsm8k(pred, gold):\n",
    "    p, g = extract_number(pred), extract_number(gold)\n",
    "    return p is not None and g is not None and float(p) == float(g)\n",
    "\n",
    "def score_math(pred, gold):\n",
    "    p, g = extract_boxed(pred), extract_boxed(gold)\n",
    "    return p is not None and g is not None and p.strip() == g.strip()\n",
    "\n",
    "def score_bbh(pred, gold):\n",
    "    return gold.strip().lower() in pred.strip().lower()\n",
    "\n",
    "DATASET_CONFIG = {\n",
    "    'gsm8k':         {'loader': load_gsm8k,         'scorer': score_gsm8k, 'label': 'GSM8K'},\n",
    "    'math':          {'loader': load_math,           'scorer': score_math,  'label': 'MATH'},\n",
    "    'bigbench_hard': {'loader': load_bigbench_hard,  'scorer': score_bbh,   'label': 'BIG-Bench Hard'},\n",
    "}\n",
    "print('✅ Dataset loaders ready: GSM8K, MATH, BIG-Bench Hard')\n"
   ]
  },
