    "section_header(9, 'Publication Summary Table', '2 min')\n",
    "\n",
    "rows = []\n",
    "for ds_name, res in MULTI_RESULTS.items():\n",
    "    if 'error' in res: continue\n",
    "    b = res['baseline']; p = res['pruned']\n",
    "    bci = res['baseline_ci']; pci = res['pruned_ci']\n",
    "    pair = res['paired']\n",
    "    rows.append({\n",
    "        'Dataset': res['label'],\n",
    "        'Baseline Acc': f\"{b['accuracy']:.2%}\",\n",
    "        'Baseline 95% CI': f\"[{bci['ci_low']:.2%}, {bci['ci_high']:.2%}]\",\n",
    "        'Pruned Acc': f\"{p['accuracy']:.2%}\",\n",
    "        'Pruned 95% CI': f\"[{pci['ci_low']:.2%}, {pci['ci_high']:.2%}]\",\n",
    "        'Δ Acc': f\"{p['accuracy']-b['accuracy']:+.2%}\",\n",
    "        'p-value': f\"{pair['p_value']:.4f}\",\n",
    "        'Effect Size': f\"{pair['effect_size']:.3f}\",\n",
    "    })\n",
    "\n",
    "# Add latency row if available\n",
    "if exp_latency and 'speedup' in exp_latency:\n",
    "    rows.append({\n",
    "        'Dataset': 'Latency (GSM8K)',\n",
    "        'Baseline Acc': f\"{exp_latency['baseline_mean']:.1f} ms\",\n",
    "        'Baseline 95% CI': f\"±{exp_latency['baseline_std']:.1f}\",\n",
    "        'Pruned Acc': f\"{exp_latency['pruned_mean']:.1f} ms\",\n",
    "        'Pruned 95% CI': f\"±{exp_latency['pruned_std']:.1f}\",\n",
    "        'Δ Acc': f\"{exp_latency['speedup']:+.1%} speedup\",\n",
    "        'p-value': '—', 'Effect Size': '—'\n",
    "    })\n",
    "\n",
    "summary_df = pd.DataFrame(rows)\n",
    "display(HTML(summary_df.to_html(index=False, border=1)))\n",
    "\n",
    "# Export CSV and LaTeX\n",
    "csv_path = RESULTS_DIR / 'publication_summary.csv'\n",
