   "source": ["## Section 5 — Latency Benchmarking"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "section_header(5, 'Latency Benchmarking', '20 min')\n",
    "exp_latency = partial_results.get('exp_latency', {})\n",
    "\n",
    "LATENCY_PROMPTS = [\n",
    "    'What is 25% of 180?', 'If a train travels 60 mph for 2.5 hours, how far?',\n",
    "    'Solve: 3x + 7 = 22', 'What is the derivative of x^3 + 2x?',\n",
    "    'A rectangle has area 48 and width 6. What is the length?',\n",
    "] * 20  # 100 prompts total\n",
    "\n",
    "def measure_latency(system, use_pruning, prompts, num_runs=50):\n",
    "    prompts = prompts[:num_runs]\n",
    "    # Warmup\n",
    "    for p in prompts[:5]: system.generate(p, use_pruning=use_pruning, max_new_tokens=50)\n",
    "    latencies = []\n",
    "    for p in tqdm(prompts, desc=f\"Latency ({'pruned' if use_pruning else 'baseline'})\"):\n",
    "        if torch.cuda.is_available():\n",
    "            s, e = torch.cuda.Event(enable_timing=True), torch.cuda.Event(enable_timing=True)\n",
    "            s.record()\n",
    "            system.generate(p, use_pruning=use_pruning, max_new_tokens=50)\n",
    "            e.record(); torch.cuda.synchronize()\n",
    "            latencies.append(s.elapsed_time(e))\n",
    "        else:\n",
    "            t0 = time.time()\n",
    "            system.generate(p, use_pruning=use_pruning, max_new_tokens=50)\n",
    "            latencies.append((time.time()-t0)*1000)\n",
    "    return np.array(latencies)\n",
    "\n",
    "if not exp_latency:\n",
    "    try:\n",
    "        base_lat = measure_latency(system, False, LATENCY_PROMPTS)\n",
    "        prn_lat  = measure_latency(system, True,  LATENCY_PROMPTS)\n",
    "        speedup  = (base_lat.mean() - prn_lat.mean()) / base_lat.mean()\n",
    "        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "        axes[0].hist(base_lat, bins=20, alpha=0.6, label='Baseline', color='#3498db')\n",
    "        axes[0].hist(prn_lat,  bins=20, alpha=0.6, label='Pruned',   color='#e74c3c')\n",
    "        axes[0].set_title('Latency Distribution (50 runs)'); axes[0].set_xlabel('ms'); axes[0].legend()\n",
    "        axes[1].boxplot([base_lat, prn_lat], labels=['Baseline', 'Pruned'], patch_artist=True,\n",
    "                        boxprops=dict(facecolor='lightblue'))\n",
    "        axes[1].set_title('Latency Boxplot'); axes[1].set_ylabel('ms')\n",
    "        plt.tight_layout(); save_figure(fig, 'latency_benchmarks')\n",
    "        exp_latency = {\n",
    "            'baseline_mean': float(base_lat.mean()), 'baseline_std': float(base_lat.std()),\n",
    "            'pruned_mean': float(prn_lat.mean()),   'pruned_std': float(prn_lat.std()),\n",
    "            'speedup': float(speedup),\n",
    "        }\n",
    "        print(f'⚡ Speedup: {speedup:.1%} | {base_lat.mean():.1f}ms → {prn_lat.mean():.1f}ms')\n",
    "    except Exception as e:\n",
    "        print(f'❌ Latency benchmark failed: {e}'); exp_latency = {'error': str(e)}\n",
    "    finally:\n",
    "        partial_results['exp_latency'] = exp_latency\n",
    "        save_partial()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Section 6 — Ablation Study"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "section_header(6, 'Ablation Study (hidden_dim × temperature)', '30 min')\n",
    "exp_ablation = partial_results.get('exp_ablation', {})\n",
    "\n",
    "if not exp_ablation:\n",
    "    ablation_rows = []\n",
    "    gsm_examples = load_gsm8k(max_samples=50)  # small subset for ablation speed\n",
    "    for hd in [64, 128]:\n",
    "        for temp in [0.7, 1.0, 1.3]:\n",
    "            for hard in [False, True]:\n",
    "                try:\n",
    "                    sys_abl = MicrogliaPruningSystem(\n",
    "                        model='microsoft/phi-3-mini-4k-instruct',\n",
    "                        num_heads=32, hidden_dim=hd,\n",
    "                        device='cuda' if torch.cuda.is_available() else 'cpu',\n",
    "                        seed=SEED, temperature=temp\n",
    "                    )\n",
    "                    res = evaluate_dataset(sys_abl, gsm_examples, score_gsm8k,\n",
    "                                          use_pruning=True, max_new_tokens=128,\n",
    "                                          desc=f'hd={hd},T={temp},hard={hard}')\n",
    "                    ablation_rows.append({\n",
    "                        'hidden_dim': hd, 'temperature': temp, 'hard_prune': hard,\n",
    "                        'accuracy': res['accuracy'], 'sparsity': res.get('sparsity', None)\n",
    "                    })\n",
    "                    free_memory(sys_abl)\n",
    "                except Exception as e:\n",
    "                    ablation_rows.append({'hidden_dim': hd, 'temperature': temp, 'hard_prune': hard, 'error': str(e)})\n",
    "    # Heatmap\n",
    "    abl_df = pd.DataFrame([r for r in ablation_rows if 'accuracy' in r])\n",
    "    if not abl_df.empty:\n",
    "        pivot = abl_df[abl_df['hard_prune']==False].pivot(index='hidden_dim', columns='temperature', values='accuracy')\n",
    "        fig, ax = plt.subplots(figsize=(8, 4))\n",
    "        sns.heatmap(pivot, annot=True, fmt='.3f', cmap='YlGnBu', ax=ax)\n",
    "        ax.set_title('Ablation: Accuracy vs hidden_dim × temperature (soft pruning)')\n",
    "        plt.tight_layout(); save_figure(fig, 'ablation_heatmap')\n",
    "    exp_ablation = {'ablation_results': ablation_rows}\n",
    "    partial_results['exp_ablation'] = exp_ablation; save_partial()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Section 7 — Pareto Frontier Analysis"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "section_header(7, 'Pareto Frontier: Accuracy vs Latency', '20 min')\n",
    "exp_pareto = partial_results.get('exp_pareto', {})\n",
    "\n",
    "if not exp_pareto:\n",
    "    try:\n",
    "        budgets = [0.35, 0.45, 0.55, 0.65, 0.75, 0.85, 0.95]\n",
    "        pareto_rows = []\n",
    "        gsm_small = load_gsm8k(max_samples=60)\n",
    "        for bgt in tqdm(budgets, desc='Pareto sweep'):\n",
    "            res = evaluate_dataset(system, gsm_small, score_gsm8k, use_pruning=True,\n",
    "                                   max_new_tokens=128, desc=f'budget={bgt}')\n",
    "            lat = measure_latency(system, True, LATENCY_PROMPTS, num_runs=20)\n",
    "            pareto_rows.append(ParetoPoint(\n",
    "                label=f'b={bgt}',\n",
    "                accuracy=res['accuracy'],\n",
    "                latency_ms=float(lat.mean()),\n",
    "                sparsity=bgt\n",
    "            ))\n",
    "        frontier = compute_pareto_frontier(pareto_rows)\n",
    "        fig, ax = plt.subplots(figsize=(9, 6))\n",
    "        for p in pareto_rows:\n",
    "            color = '#e74c3c' if p in frontier else '#95a5a6'\n",
    "            ax.scatter(p.latency_ms, p.accuracy, color=color, s=80, zorder=3)\n",
    "            ax.annotate(p.label, (p.latency_ms, p.accuracy), textcoords='offset points', xytext=(5,5), fontsize=8)\n",
    "        front_sorted = sorted(frontier, key=lambda x: x.latency_ms)\n",
    "        ax.plot([p.latency_ms for p in front_sorted], [p.accuracy for p in front_sorted],\n",
    "                'r--', lw=2, label='Pareto Frontier')\n",
    "        ax.set_xlabel('Latency (ms)'); ax.set_ylabel('Accuracy'); ax.legend()\n",
    "        ax.set_title('Accuracy–Latency Pareto Frontier')\n",
    "        plt.tight_layout(); save_figure(fig, 'pareto_frontier')\n",
    "        exp_pareto = {'pareto_points': len(pareto_rows), 'frontier_size': len(frontier),\n",
    "                      'frontier_labels': [p.label for p in frontier]}\n",
    "    except Exception as e:\n",
    "        print(f'❌ Pareto failed: {e}'); exp_pareto = {'error': str(e), 'frontier_labels': []}\n",
    "    finally:\n",
    "        partial_results['exp_pareto'] = exp_pareto; save_partial()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Section 8 — Lottery Ticket Analysis"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "section_header(8, 'Lottery Ticket Hypothesis Analysis', '15 min')\n",
    "exp_theory = partial_results.get('exp_theory', {})\n",
    "\n",
    "def extract_masks(system, prompt='What is 2+2?'):\n",
    "    system.model.eval()\n",
    "    with torch.no_grad(): system.generate(prompt, use_pruning=True, max_new_tokens=8)\n",
    "    masks = []\n",
    "    for li, layer in enumerate(system.get_layers()):\n",
    "        attn = layer.self_attn\n",
    "        if hasattr(attn, 'last_masks') and attn.last_masks is not None:\n",
    "            m = attn.last_masks.detach().cpu().numpy()\n",
    "            masks.append(m[0] if m.ndim==2 else m)\n",
    "        elif hasattr(system, 'agents') and li in system.agents:\n",
    "            dummy = torch.zeros(1, system.num_heads*2, device=system.device)\n",
    "            with torch.no_grad(): m = system.agents[li](dummy).detach().cpu().numpy()[0]\n",
    "            masks.append(m)\n",
    "        else:\n",
    "            masks.append(np.ones(system.num_heads))\n",
    "    return np.stack(masks, axis=0)\n",
    "\n",
    "if not exp_theory:\n",
    "    try:\n",
    "        m1 = extract_masks(system, 'What is 2+2?')\n",
    "        m2 = extract_masks(system, 'Solve: 3x + 5 = 14')\n",
    "        m3 = extract_masks(system, 'A bag has 5 red and 3 blue marbles. Probability of red?')\n",
    "        traj = np.stack([m1, m2, m3], axis=0)\n",
    "        analysis = analyze_lottery_ticket_behavior(mask_trajectory=traj)\n",
    "        # Visualize mask heatmap\n",
    "        fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
    "        for ax, m, title in zip(axes, [m1, m2, m3],\n",
    "            ['Simple arithmetic', 'Algebra', 'Probability']):\n",
    "            im = ax.imshow(m, aspect='auto', cmap='RdYlGn', vmin=0, vmax=1)\n",
    "            ax.set_title(f'Pruning masks: {title}')\n",
    "            ax.set_xlabel('Head'); ax.set_ylabel('Layer')\n",
    "            plt.colorbar(im, ax=ax, fraction=0.046)\n",
    "        plt.tight_layout(); save_figure(fig, 'mask_heatmaps')\n",
    "        exp_theory = {'analysis': analysis}\n",
    "    except Exception as e:\n",
    "        print(f'❌ Theory analysis failed: {e}')\n",
    "        exp_theory = {'error': str(e), 'analysis': {'mean_overlap': 0.0, 'overlap_std': 0.0}}\n",
    "    finally:\n",
    "        partial_results['exp_theory'] = exp_theory; save_partial()\n"
   ]
  },
